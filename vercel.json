{
  "crons": [
    {
      "path": "/api/cron/publish-scheduled",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/digest-daily",
      "schedule": "15 13 * * *"
    },
    {
      "path": "/api/cron/digest-weekly",
      "schedule": "15 13 * * 1"
    },
    {
      "path": "/api/cron/digest-monthly",
      "schedule": "15 13 1 * *"
    }
  ]
}
