generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model City {
  id                    Int            @id @default(autoincrement())
  stateCode             String         @db.VarChar(2)
  stateName             String         @db.VarChar(100)
  name                  String         @db.VarChar(200)
  slug                  String         @db.VarChar(200)
  summary               String         @db.Text
  recentMeetingsSummary String?        @db.Text
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  meetings              Meeting[]
  subscriptions         Subscription[]
  interestAreas         InterestArea[]

  @@unique([stateCode, slug])
  @@index([stateCode])
}

enum MeetingStatus {
  SCHEDULED
  OCCURRED
  PUBLISHED
  CANCELED
}

model Meeting {
  id                     Int                         @id @default(autoincrement())
  cityId                 Int
  slug                   String                      @unique @db.VarChar(500)
  title                  String                      @db.VarChar(500)
  date                   DateTime
  // Default is PUBLISHED, not SCHEDULED: until the transcriber's stub-write
  // path ships (see FEAT-EARLY-ALERTS-001 phase 3), every Meeting row is
  // still created post-transcription by cmd_publish, which never sets this
  // column explicitly. Only the new stub-upsert path sets SCHEDULED.
  status                 MeetingStatus               @default(PUBLISHED)
  agendaLastFetchedAt    DateTime?
  summary                String?                     @db.Text
  summaryModel           String?                     @db.VarChar(200)
  logline                String?                     @db.Text
  timelineBullets        Json?
  youtubeUrl             String?                     @db.VarChar(500)
  youtubeOffsetSeconds   Float?
  youtubeOffsetModel     Json?
  granicusUrl            String?                     @db.VarChar(500)
  videoUrl               String?                     @db.VarChar(1000)
  videoProvider          String?                     @db.VarChar(50)
  minutesText            String?                     @db.Text
  minutesUrl             String?                     @db.VarChar(500)
  minutesGeneratedAt     DateTime?
  minutesTotalItems      Int?
  minutesAlignedCount    Int?
  // Transcript accuracy review — sourced from the transcriber's existing
  // review_status.json (quality_score/reviewed_by/notes), independent of
  // meetingReviewed below (see FEAT-REVIEW-FLAGS-001).
  transcriptReviewed     Boolean?
  transcriptReviewedAt   DateTime?
  transcriptReviewedBy   String?                     @db.VarChar(200)
  transcriptQualityScore Int?
  transcriptReviewNotes  String?                     @db.Text
  // Whole-meeting/summary content review — a separate, admin-toggled flag
  // with no transcriber-side equivalent (not derived from any pipeline
  // artifact).
  meetingReviewed        Boolean?
  meetingReviewedAt      DateTime?
  meetingReviewedBy      String?                     @db.VarChar(200)
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  city                   City                        @relation(fields: [cityId], references: [id], onDelete: Cascade)
  lines                  TranscriptLine[]
  summaryItems           MeetingSummaryItem[]
  documents              MeetingDocument[]
  segments               MeetingSegment[]
  minutesItems           MinutesItem[]
  topicSummaries         TopicSummary[]
  speakerSummaries       SpeakerSummary[]
  interestAreaStatuses   InterestAreaMeetingStatus[]
  alerts                 Alert[]
  agendaItemVersions     AgendaItemVersion[]

  @@index([cityId])
  @@index([date])
}

/// Append-only history of an agenda item's content as scraped pre-meeting.
/// Every re-scrape that detects a content change inserts a new revision
/// rather than overwriting, so older "what did the agenda say" states stay
/// visible (see FEAT-EARLY-ALERTS-001).
model AgendaItemVersion {
  id           Int      @id @default(autoincrement())
  meetingId    Int
  sourceItemId String   @db.VarChar(100)
  itemNumber   String?  @db.VarChar(50)
  title        String   @db.Text
  description  String?  @db.Text
  documentUrls Json?
  revision     Int      @default(1)
  scrapedAt    DateTime @default(now())
  createdAt    DateTime @default(now())
  meeting      Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, sourceItemId, revision])
  @@index([meetingId, sourceItemId])
}

model TranscriptLine {
  id                Int     @id @default(autoincrement())
  meetingId         Int
  lineIndex         Int
  startTime         Float
  endTime           Float
  speaker           String  @db.VarChar(200)
  speakerName       String? @db.VarChar(200)
  text              String  @db.Text
  confidence        Float   @default(0.0)
  globalSpeakerUuid String? @db.VarChar(36)
  meeting           Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, lineIndex])
  @@index([meetingId])
  @@index([globalSpeakerUuid])
}

model MeetingSummaryItem {
  id               Int     @id @default(autoincrement())
  meetingId        Int
  type             String  @db.VarChar(100)
  text             String  @db.Text
  sortOrder        Int
  startTimeSeconds Float?
  endTimeSeconds   Float?
  timecodeLabel    String? @db.VarChar(50)
  segmentIndex     Int?
  segmentIndexEnd  Int?
  linkStatus       String? @db.VarChar(20)
  confidence       Float?
  speaker          String? @db.VarChar(200)
  position         String? @db.VarChar(50)
  notes            String? @db.Text
  references       Json?
  meeting          Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, type, sortOrder])
  @@index([meetingId])
}

model MeetingDocument {
  id                   Int     @id @default(autoincrement())
  meetingId            Int
  title                String  @db.VarChar(500)
  url                  String  @db.VarChar(1000)
  documentType         String? @db.VarChar(100)
  associatedAgendaItem String? @db.Text
  meeting              Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, url])
  @@index([meetingId])
}

model MeetingSegment {
  id                     Int       @id @default(autoincrement())
  meetingId              Int
  itemId                 String    @db.VarChar(100)
  itemNumber             String    @db.VarChar(50)
  title                  String    @db.VarChar(500)
  startTime              Float
  endTime                Float
  durationSeconds        Float?
  skip                   Boolean   @default(false)
  skipReason             String?   @db.VarChar(100)
  sortOrder              Int
  discussionSummary      String?   @db.Text
  officialAction         String?   @db.Text
  tags                   Json?
  speakerPositions       Json?
  keyQuotes              Json?
  publicComments         Json?
  discrepancies          Json?
  sourcesUsed            Json?
  sourceMinutesAvailable Boolean?
  sourceAgendaAvailable  Boolean?
  provider               String?   @db.VarChar(100)
  model                  String?   @db.VarChar(200)
  generatedAt            DateTime?
  meeting                Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, itemId])
  @@index([meetingId])
}

model MinutesItem {
  id                  Int     @id @default(autoincrement())
  meetingId           Int
  itemId              String  @db.VarChar(100)
  itemNumber          String  @db.VarChar(50)
  title               String  @db.VarChar(500)
  startTime           Float
  endTime             Float
  durationSeconds     Float?
  skip                Boolean @default(false)
  sortOrder           Int
  parentItemId        String? @db.VarChar(100)
  itemType            String  @db.VarChar(50)
  alignmentConfidence String? @db.VarChar(20)
  alignmentMethod     String? @db.VarChar(100)
  agendaItemId        String? @db.VarChar(50)
  startTimecode       String? @db.VarChar(20)
  endTimecode         String? @db.VarChar(20)
  textLineStart       Int?
  textLineEnd         Int?
  segmentIndices      Json?
  meeting             Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, itemId])
  @@index([meetingId])
}

model TopicSummary {
  id               Int       @id @default(autoincrement())
  meetingId        Int
  topicId          String    @db.VarChar(100)
  title            String    @db.VarChar(500)
  startTime        Float
  endTime          Float
  sortOrder        Int
  summaryText      String?   @db.Text
  keyPoints        Json?
  speakers         Json?
  speakerPositions Json?
  outcome          String?   @db.Text
  tags             Json?
  provider         String?   @db.VarChar(100)
  model            String?   @db.VarChar(200)
  generatedAt      DateTime?
  meeting          Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, topicId])
  @@index([meetingId])
}

model SpeakerSummary {
  id               Int       @id @default(autoincrement())
  meetingId        Int
  speakerUuid      String?   @db.VarChar(36)
  speakerName      String    @db.VarChar(200)
  segmentCount     Int?
  speakingTime     Float?
  sortOrder        Int
  summaryText      String?   @db.Text
  keyQuotes        Json?
  actionsOrMotions Json?
  positionsByTopic Json?
  provider         String?   @db.VarChar(100)
  model            String?   @db.VarChar(200)
  generatedAt      DateTime?
  meeting          Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, speakerUuid])
  @@index([meetingId])
}

model InterestArea {
  id                 Int                         @id @default(autoincrement())
  cityId             Int
  slug               String                      @db.VarChar(200)
  name               String                      @db.VarChar(500)
  description        String?                     @db.Text
  source             String?                     @db.VarChar(50)
  statusSummary      String?                     @db.Text
  meetingsDiscussed  Int?
  totalMeetings      Int?
  mostRecentActivity String?                     @db.VarChar(500)
  generatedAt        DateTime?
  runId              String?                     @db.VarChar(100)
  sortOrder          Int                         @default(0)
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  city               City                        @relation(fields: [cityId], references: [id], onDelete: Cascade)
  meetingStatuses    InterestAreaMeetingStatus[]
  subscriptions      Subscription[]
  alerts             Alert[]

  @@unique([cityId, slug])
  @@index([cityId])
}

enum InterestAreaStatusPhase {
  PREVIEW
  POSTMEETING
}

model InterestAreaMeetingStatus {
  id                 Int                     @id @default(autoincrement())
  interestAreaId     Int
  meetingId          Int
  phase              InterestAreaStatusPhase @default(POSTMEETING)
  // Pre-meeting PREVIEW rows don't yet know whether the topic was actually
  // discussed, hence nullable; POSTMEETING rows always set it.
  discussed          Boolean?
  discussionExpected Boolean?
  signalStrength     String?                 @db.VarChar(10)
  summary            String?                 @db.Text
  confidence         Float?
  runId              String?                 @db.VarChar(100)
  startTimeSeconds   Float?
  endTimeSeconds     Float?
  timecodeLabel      String?                 @db.VarChar(50)
  sourceItemId       String?                 @db.VarChar(100)
  createdAt          DateTime                @default(now())
  interestArea       InterestArea            @relation(fields: [interestAreaId], references: [id], onDelete: Cascade)
  meeting            Meeting                 @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([interestAreaId, meetingId, phase])
  @@index([meetingId])
}

enum SubscriptionKind {
  SITE_UPDATES
  CITY_COVERAGE_REQUEST
  CITY_UPDATES
  TOPIC_IN_CITY_UPDATES
  TOPIC_IN_CITY_COVERAGE_REQUEST
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  UNSUBSCRIBED
}

enum AlertFrequency {
  INSTANT
  DAILY
  WEEKLY
  MONTHLY
}

model Subscriber {
  id            Int            @id @default(autoincrement())
  email         String         @unique @db.VarChar(320)
  isAdmin       Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
  digestBatches DigestBatch[]
}

model Subscription {
  id                 Int                @id @default(autoincrement())
  subscriberId       Int
  subscriber         Subscriber         @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  kind               SubscriptionKind
  cityId             Int?
  city               City?              @relation(fields: [cityId], references: [id], onDelete: SetNull)
  requestedCityName  String?            @db.VarChar(200)
  interestAreaId     Int?
  interestArea       InterestArea?      @relation(fields: [interestAreaId], references: [id], onDelete: SetNull)
  requestedTopicName String?            @db.VarChar(200)
  status             SubscriptionStatus @default(PENDING)
  frequency          AlertFrequency     @default(INSTANT)
  confirmToken       String             @unique @db.VarChar(64)
  unsubscribeToken   String             @unique @db.VarChar(64)
  confirmedAt        DateTime?
  unsubscribedAt     DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deliveries         AlertDelivery[]

  @@unique([subscriberId, kind, cityId, requestedCityName, interestAreaId, requestedTopicName])
  @@index([kind, cityId, interestAreaId, status])
}

enum AlertType {
  MEETING_UPDATED
  MEETING_UPCOMING
  INTEREST_AREA_UPDATED
}

enum AlertStatus {
  DRAFTED
  SENT_TO_ADMINS
  PUBLISHED
  CANCELED
}

model Alert {
  id             Int             @id @default(autoincrement())
  type           AlertType
  meetingId      Int?
  meeting        Meeting?        @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  interestAreaId Int?
  interestArea   InterestArea?   @relation(fields: [interestAreaId], references: [id], onDelete: Cascade)
  status         AlertStatus     @default(DRAFTED)
  content        Json
  scheduledFor   DateTime?
  sentToAdminsAt DateTime?
  publishedAt    DateTime?
  publishedBy    String?         @db.VarChar(320)
  canceledAt     DateTime?
  canceledBy     String?         @db.VarChar(320)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deliveries     AlertDelivery[]

  @@index([type, status])
  @@index([meetingId])
  @@index([interestAreaId])
  @@index([status, scheduledFor])
}

enum AlertDeliveryStatus {
  PENDING
  SENT
  SKIPPED
}

/// Per-subscription fan-out ledger. Decouples "an alert was published" from
/// "a given subscriber received it," which is what lets DAILY/WEEKLY/MONTHLY
/// deliveries get bundled into a single digest email across alerts, while
/// INSTANT deliveries are sent (and marked SENT) immediately at publish time.
model AlertDelivery {
  id             Int                 @id @default(autoincrement())
  alertId        Int
  alert          Alert               @relation(fields: [alertId], references: [id], onDelete: Cascade)
  subscriptionId Int
  subscription   Subscription        @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  // Snapshot of the subscription's frequency at fan-out time, so a later
  // frequency change doesn't retroactively reroute an already-queued delivery.
  frequency      AlertFrequency
  status         AlertDeliveryStatus @default(PENDING)
  sentAt         DateTime?
  digestBatchId  Int?
  digestBatch    DigestBatch?        @relation(fields: [digestBatchId], references: [id], onDelete: SetNull)
  createdAt      DateTime            @default(now())

  @@unique([alertId, subscriptionId])
  @@index([subscriptionId, status, frequency])
  @@index([digestBatchId])
}

/// One row per digest email actually sent to a subscriber for a single
/// cadence tick, grouping the AlertDeliveries bundled into that email.
model DigestBatch {
  id           Int             @id @default(autoincrement())
  subscriberId Int
  subscriber   Subscriber      @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  frequency    AlertFrequency
  sentAt       DateTime        @default(now())
  deliveries   AlertDelivery[]

  @@index([subscriberId, frequency, sentAt])
}

/// TEMPORARY (2026-07-09): DB-backed fallback for the cron drain endpoint's
/// auth, used only until CRON_SECRET can be set on the Vercel project
/// (currently no one has dashboard access). A GitHub Actions workflow drives
/// the scheduled drain in the meantime, presenting a token stored here
/// instead of relying on Vercel Cron's env-var-only auth. Delete this model
/// + its migration and app/api/cron/publish-scheduled's DB-fallback check
/// once CRON_SECRET is set on Vercel and the GH Actions workflow is removed.
model CronAuthToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(128)
  label     String?  @db.VarChar(200)
  createdAt DateTime @default(now())
}
