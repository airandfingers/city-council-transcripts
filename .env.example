# =============================================================================
# Local development (Docker Postgres — see docker-compose.yml)
# =============================================================================
# Copy this file to `.env` and uncomment the local block to develop against the
# Docker Postgres instance. Run `docker compose up -d postgres` first.
#
# DATABASE_URL="postgresql://ccc:ccc@localhost:5432/ccc_dev?schema=public"
# DIRECT_URL="postgresql://ccc:ccc@localhost:5432/ccc_dev?schema=public"

# =============================================================================
# Production / hosted (Neon)
# =============================================================================
# Neon pooled connection string for runtime (use -pooler hostname)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/DBNAME?sslmode=require&connect_timeout=10&connection_limit=1"

# Neon direct connection string for Prisma CLI commands (db push/migrations)
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require&connect_timeout=10"
