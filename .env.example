# Neon pooled connection string for runtime (use -pooler hostname)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/DBNAME?sslmode=require&connect_timeout=10&connection_limit=1"

# Neon direct connection string for Prisma CLI commands (db push/migrations)
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require&connect_timeout=10"
