{
  "name": "city-council-transcripts",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:local": "prisma db push --config prisma.config.docker.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && npm run db:seed",
    "db:import": "tsx scripts/import-transcription-export.mjs",
    "db:contract": "node scripts/generate-contract.mjs",
    "publish:admins": "node scripts/publish-to-admins.mjs",
    "publish:city": "node scripts/publish.mjs",
    "test": "npm run test:validate",
    "test:gates": "node scripts/validate/run-gates.mjs --all",
    "test:validate": "node scripts/validate/run-gates.mjs --all",
    "test:quick": "npm run lint && npm run typecheck",
    "test:prepush": "npm run test:gates",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^6.19.0",
    "@prisma/client": "^6.19.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.6",
    "dotenv": "^17.2.3",
    "next": "16.1.6",
    "prisma": "^6.19.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.12.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.4.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/youtube": "^0.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
